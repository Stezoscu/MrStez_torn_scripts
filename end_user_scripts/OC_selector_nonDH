        ${settings.safeMode ? `· Filtered: ${result.rejected.length}` : ''}
      </div>

      ${renderRejectedSummary(result.rejected)}
      ${renderFooterActions()}
      ${renderFooterNote()}
    `;

    bindPanelActions();
  }

  function renderHeader() {
    const hasKey = !!getApiKey();

    return `
      <div style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
        <div style="font-weight:700;">${escapeHtml(SCRIPT.name)}</div>
        <div class="ace-oc-small ace-oc-muted">v${escapeHtml(SCRIPT.version)}</div>
      </div>
      <div class="ace-oc-row ace-oc-small">
        API key:
        ${hasKey ? '<span class="ace-oc-good">saved</span>' : '<span class="ace-oc-warn">not set</span>'}
        <button class="ace-oc-btn" data-ace-action="set-key">Set/Change</button>
        <button class="ace-oc-btn ace-oc-btn-danger" data-ace-action="clear-key">Clear</button>
      </div>
    `;
  }

  function renderSettingsSummary(settings, profile, source, cacheAgeText) {
    return `
      <div class="ace-oc-row ace-oc-small">
        Safe Mode:
        <button class="ace-oc-btn" data-ace-action="toggle-safe">
          ${settings.safeMode ? 'On' : 'Off'}
        </button>
        <select data-ace-action="profile-select" style="background:#222; color:#eee; border:1px solid #555; border-radius:5px; padding:3px;">
          ${Object.entries(SAFE_PROFILES).map(([key, p]) => `
            <option value="${escapeHtml(key)}" ${key === settings.safeModeProfile ? 'selected' : ''}>
              ${escapeHtml(p.label)}
            </option>
          `).join('')}
        </select>
      </div>

      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        Filter: CPR ≥ ${profile.cprFloor}%,
        high-impact CPR ≥ ${profile.highImpactCprFloor}%,
        max risk ${Math.round(profile.maxRiskDamageRatio * 100)}%.
      </div>

      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        Source: ${source === 'cache' ? `cache${cacheAgeText ? ` (${escapeHtml(cacheAgeText)})` : ''}` : 'live API'}
        · Cache:
        <button class="ace-oc-btn" data-ace-action="toggle-cache">
          ${settings.cacheEnabled ? 'On' : 'Off'}
        </button>
      </div>
    `;
  }

  function renderRejectedSummary(rejected) {
    if (!rejected || !rejected.length) return '';

    const top = rejected.slice(0, 3);

    return `
      <div class="ace-oc-divider"></div>
      <details>
        <summary class="ace-oc-small ace-oc-warn" style="cursor:pointer;">
          Safe Mode filtered ${rejected.length} role(s)
        </summary>
        <div class="ace-oc-small" style="margin-top:6px;">
          ${top.map(r => `
            <div class="ace-oc-row">
              <b>${escapeHtml(r.crime)}</b> — ${escapeHtml(r.role)}
              <br>
              CPR ${r.cpr}% · Impact ${formatPercent(r.weight)}
              <br>
              <span class="ace-oc-muted">${escapeHtml(r.safeReason)}</span>
            </div>
          `).join('')}
          ${rejected.length > top.length ? `
            <div class="ace-oc-row ace-oc-muted">
              Showing top ${top.length} by EV only.
            </div>
          ` : ''}
        </div>
      </details>
    `;
  }

  function renderFooterActions() {
    return `
      <div class="ace-oc-divider"></div>
      <div class="ace-oc-row">
        <button class="ace-oc-btn ace-oc-btn-primary" data-ace-action="refresh">Refresh</button>
        <button class="ace-oc-btn" data-ace-action="clear-cache">Clear Cache</button>
      </div>
    `;
  }

  function renderFooterNote() {
    return `
      <div class="ace-oc-divider"></div>
      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        Member script only. No leader checks, no missing-item lists, no planning controls.
        DOM fallback mode will be added later for members without faction API access.
      </div>
    `;
  }

  function renderMessage(title, detail) {
    if (!panel) return;

    panel.innerHTML = `
      ${renderHeader()}
      <div class="ace-oc-row ace-oc-warn">${escapeHtml(title)}</div>
      ${detail ? `<div class="ace-oc-row ace-oc-small ace-oc-muted">${escapeHtml(detail)}</div>` : ''}
      ${renderFooterActions()}
      ${renderFooterNote()}
    `;

    bindPanelActions();
  }

  function renderApiError(error) {
    if (!panel) return;

    const code = error.code;
    const msg = error.error || 'Unknown API error';
    const explanation = explainApiError(code, msg);

    panel.innerHTML = `
      ${renderHeader()}
      <div class="ace-oc-row ace-oc-bad">
        API error ${code != null ? `#${escapeHtml(code)}` : ''}: ${escapeHtml(msg)}
      </div>
      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        ${explanation}
      </div>
      <div class="ace-oc-row">
        <button class="ace-oc-btn ace-oc-btn-primary" data-ace-action="set-key">Set/Change API Key</button>
        <button class="ace-oc-btn ace-oc-btn-danger" data-ace-action="clear-key">Clear Key</button>
        <button class="ace-oc-btn" data-ace-action="refresh">Retry</button>
      </div>
      ${renderFooterNote()}
    `;

    bindPanelActions();
  }

  function explainApiError(code, msg) {
    const lower = String(msg || '').toLowerCase();

    if (
      code === 2 ||
      code === 7 ||
      code === 10 ||
      lower.includes('incorrect key') ||
      lower.includes('invalid') ||
      lower.includes('key')
    ) {
      return 'Your API key may be missing, incorrect, expired, or entered wrongly. Try setting/changing the key.';
    }

    if (
      code === 13 ||
      code === 18 ||
      lower.includes('permission') ||
      lower.includes('access') ||
      lower.includes('faction')
    ) {
      return 'This endpoint needs faction crime access. A normal public-only key may not be enough. If members should not have faction API access, use the later DOM fallback version instead.';
    }

    if (
      code === 5 ||
      code === 14 ||
      lower.includes('too many') ||
      lower.includes('rate')
    ) {
      return 'This looks like an API rate-limit issue. The script has lightweight caching, so wait briefly or use cached data where possible.';
    }

    return 'The API rejected the request. Check the key, faction permissions, and whether the Torn API is currently available.';
  }

  function renderNetworkError(e) {
    if (!panel) return;

    panel.innerHTML = `
      ${renderHeader()}
      <div class="ace-oc-row ace-oc-bad">
        Network/API request failed.
      </div>
      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        ${escapeHtml(e.message || String(e))}
      </div>
      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        This can happen on mobile/TornPDA if the connection is unstable, or if Torn/API access is temporarily blocked.
      </div>
      ${renderFooterActions()}
      ${renderFooterNote()}
    `;

    bindPanelActions();
  }

  function bindPanelActions() {
    if (!panel) return;

    panel.querySelectorAll('[data-ace-action]').forEach(el => {
      const action = el.getAttribute('data-ace-action');

      if (action === 'profile-select') {
        el.onchange = () => {
          const settings = getSettings();
          settings.safeModeProfile = el.value;
          saveSettings(settings);
          renderShellAndFetch(false);
        };
        return;
      }

      el.onclick = () => handleAction(action);
    });
  }

  function handleAction(action) {
    const settings = getSettings();

    if (action === 'set-key') {
      const existing = getApiKey();
      const key = prompt(
        'Enter Torn API key.\n\nThis member helper currently needs access to faction crimes.\nA public-only key may fail with a permission error.',
        existing || ''
      );

      if (key && key.trim()) {
        setApiKey(key.trim());
        clearCache();
        renderShellAndFetch(true);
      }

      return;
    }

    if (action === 'clear-key') {
      const ok = confirm('Clear the saved Torn API key for this script?');
      if (ok) {
        clearApiKey();
        clearCache();
        renderNoKey();
      }
      return;
    }

    if (action === 'toggle-safe') {
      settings.safeMode = !settings.safeMode;
      saveSettings(settings);
      renderShellAndFetch(false);
      return;
    }

    if (action === 'toggle-cache') {
      settings.cacheEnabled = !settings.cacheEnabled;
      saveSettings(settings);
      renderShellAndFetch(false);
      return;
    }

    if (action === 'refresh') {
      clearCache();
      renderShellAndFetch(true);
      return;
    }

    if (action === 'clear-cache') {
      clearCache();
      renderShellAndFetch(true);
      return;
    }
  }

  function buildCrimeUrl(crimeId) {
    return `https://www.torn.com/factions.php?step=your&type=1#/tab=crimes&crimeId=${encodeURIComponent(crimeId)}`;
  }

  function buildItemMarketUrl(itemId, itemName = '') {
    const params = new URLSearchParams({
      itemID: String(itemId)
    });

    if (itemName) {
      params.set('itemName', itemName);
    }

    return `https://www.torn.com/page.php?sid=ItemMarket#/market/view=search&${params.toString()}`;
  }

  function renderItemText(best) {
    if (!best.itemId) {
      return 'No item required';
    }

    const marketUrl = buildItemMarketUrl(best.itemId, best.itemName || '');

    if (best.itemName) {
      return `Requires item: <a href="${marketUrl}">${escapeHtml(best.itemName)}</a> (#${best.itemId})`;
    }

    return `Requires item: <a href="${marketUrl}">#${best.itemId}</a>`;
  }

  function riskClass(level) {
    if (level === 'High') return 'ace-oc-bad';
    if (level === 'Medium') return 'ace-oc-warn';
    return 'ace-oc-good';
  }

  function formatHours(hours) {
    const n = Number(hours || 0);
    if (n < 1) return `${Math.round(n * 60)}m`;
    return `${n.toFixed(1)}h`;
  }

  function formatPercent(value) {
    return `${Math.round(Number(value || 0) * 100)}%`;
  }

  function escapeHtml(str) {
    return String(str)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function syncUiToPage() {
    if (isCrimesTab()) {
      createUi();
    } else {
      removeUi();
    }
  }

  function installNavigationHooks() {
    if (window.__aceOcMemberNavHooksInstalled) return;
    window.__aceOcMemberNavHooksInstalled = true;

    const originalPushState = history.pushState;
    const originalReplaceState = history.replaceState;

    history.pushState = function () {
      const result = originalPushState.apply(this, arguments);
      window.dispatchEvent(new Event('ace-oc-member-location-change'));
      return result;
    };

    history.replaceState = function () {
      const result = originalReplaceState.apply(this, arguments);
      window.dispatchEvent(new Event('ace-oc-member-location-change'));
      return result;
    };

    window.addEventListener('popstate', () => {
      window.dispatchEvent(new Event('ace-oc-member-location-change'));
    });

    window.addEventListener('hashchange', () => {
      window.dispatchEvent(new Event('ace-oc-member-location-change'));
    });

    window.addEventListener('ace-oc-member-location-change', syncUiToPage);
  }

  function installObserver() {
    if (observer) return;

    observer = new MutationObserver(() => {
      if (location.href !== lastUrl) {
        lastUrl = location.href;
        syncUiToPage();
      }
    });

    observer.observe(document.documentElement, {
      childList: true,
      subtree: true
    });
  }

  injectStyles();
  installNavigationHooks();
  installObserver();
  syncUiToPage();
  setInterval(syncUiToPage, 1000);
})();