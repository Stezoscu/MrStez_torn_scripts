        </div>
        ${renderRejectedSummary(result.rejected)}
        ${renderFooterActions()}
        ${renderFooterNote()}
      `;

      bindPanelActions();
      return;
    }

    const best = result.best;
    const crimeUrl = buildCrimeUrl(best.crime_id);

    panel.innerHTML = `
