      </div>

      <div class="ace-oc-row ace-oc-small">
        Role impact: ${formatPercent(best.weight)}
        · Risk: <span class="${riskClass(best.risk.level)}">${escapeHtml(best.risk.level)}</span>
        · Est. risk damage: $${Math.round(best.risk.cprDamage).toLocaleString()}
      </div>

      <div class="ace-oc-row ace-oc-small ${best.safe ? 'ace-oc-good' : 'ace-oc-warn'}">
        ${escapeHtml(best.safeReason)}
      </div>

      ${best.usedWeightFallback ? `
