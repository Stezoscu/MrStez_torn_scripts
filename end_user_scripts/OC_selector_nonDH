        No API key saved.
      </div>
      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        This member helper currently needs a Torn API key that can read faction crimes.
        If your key does not have faction access, Torn may return a permission error.
      </div>
      <div class="ace-oc-row">
        <button class="ace-oc-btn ace-oc-btn-primary" data-ace-action="set-key">Set API Key</button>
      </div>
      ${renderFooterNote()}
    `;

    bindPanelActions();
  }

  async function fetchCrimes(forceRefresh) {
    if (!panel) return;

    const key = getApiKey();
    const settings = getSettings();

    if (!key) {
      renderNoKey();
      return;
    }

    panel.innerHTML = `
      ${renderHeader()}
      <div class="ace-oc-row">Loading OC data...</div>
      <div class="ace-oc-row ace-oc-small ace-oc-muted">
        ${settings.cacheEnabled && !forceRefresh ? 'Checking cache first.' : 'Forced refresh requested.'}
      </div>
    `;
    bindPanelActions();

    try {
      let data = null;
      let source = 'api';
      let cacheAgeText = '';

      if (settings.cacheEnabled && !forceRefresh) {
        const cached = readCache();
        if (cached && cached.data) {
          data = cached.data;
          source = 'cache';
          cacheAgeText = getCacheAgeText(cached.savedAt);
        }
      }

      if (!data) {
        const url = `${API.url}&key=${encodeURIComponent(key)}`;
        const res = await fetch(url);
        data = await res.json();

        if (data.error) {
          renderApiError(data.error);
          return;
        }

        if (settings.cacheEnabled) {
          writeCache(data);
        }
      }

      if (!data.crimes || !Array.isArray(data.crimes) || data.crimes.length === 0) {
        renderMessage(
          'No recruiting OCs found.',
          'The API responded successfully, but no recruiting organised crimes were returned.'
        );
        return;
      }

      const result = processCrimes(data.crimes, settings);
      renderResult(result, source, cacheAgeText);
    } catch (e) {
      renderNetworkError(e);
    }
  }

  function readCache() {
    try {
      const raw = localStorage.getItem(STORAGE.cache);
      if (!raw) return null;

      const parsed = JSON.parse(raw);
      if (!parsed || !parsed.savedAt || !parsed.data) return null;

      const age = Date.now() - parsed.savedAt;
      if (age > API.cacheTtlMs) return null;

      return parsed;
    } catch (e) {
      return null;
    }
  }

  function writeCache(data) {
    try {
      localStorage.setItem(STORAGE.cache, JSON.stringify({
        savedAt: Date.now(),
        data
      }));
    } catch (e) {
      console.warn('[OC Best Role] Failed to write cache:', e);
    }
  }

  function getCacheAgeText(savedAt) {
    if (!savedAt) return '';
    const seconds = Math.max(0, Math.round((Date.now() - savedAt) / 1000));
    if (seconds < 60) return `${seconds}s old`;
    return `${Math.round(seconds / 60)}m old`;
  }

  function processCrimes(crimes, settings) {
    const rows = [];
    const rejected = [];
    let consideredCount = 0;
    let openRoleCount = 0;
    let missingPayoutCount = 0;

    for (const crime of crimes) {
      if (!crime.slots || !crime.slots.length) continue;

      const members = crime.slots.length;
      let totalRemaining = 0;
      let filled = 0;

      for (const slot of crime.slots) {
        if (slot.user) {
          totalRemaining += 100 - (slot.user.progress || 0);
          filled++;
        } else {
          totalRemaining += 100;
        }
      }

      const stallHours = totalRemaining * 0.24;

      for (const slot of crime.slots) {
        if (slot.user) continue;

        openRoleCount++;

        const payoutMax = crimePayouts[crime.name]?.max;
        if (!payoutMax) {
          missingPayoutCount++;
          if (!warnedMissingPayouts.has(crime.name)) {
            console.warn(`[OC Best Role] Missing payout data for crime: ${crime.name}. Skipping it.`);
            warnedMissingPayouts.add(crime.name);
          }
          continue;
        }

        let weight = crimeWeights[crime.name]?.[slot.position_id];
        let usedWeightFallback = false;

        if (weight == null) {
          weight = 1 / members;
          usedWeightFallback = true;
          if (!warnedMissingWeights.has(crime.name)) {
            console.warn(`[OC Best Role] Missing weight data for crime: ${crime.name}. Using equal weighting fallback.`);
            warnedMissingWeights.add(crime.name);
          }
        }

        const cpr = normaliseCpr(slot.checkpoint_pass_rate);
        const risk = calculateRisk(weight, payoutMax, cpr);
        const ev = estPayout(weight, payoutMax, cpr, stallHours, members, filled);

        if (ev == null || Number.isNaN(ev)) continue;

        consideredCount++;

        const row = {
          crime_id: crime.id,
          crime: crime.name,
          role: `${slot.position || 'Role'} ${slot.position_number || ''}`.trim(),
          positionId: slot.position_id || '',
          ev,
          cpr,
          stall: stallHours,
          itemId: slot.item_requirement?.id || null,
          itemName: slot.item_requirement?.name || null,
          members,
          filled,
          weight,
          payoutMax,
          risk,
          usedWeightFallback
        };

        const safeCheck = checkSafeMode(row, settings);
        row.safe = safeCheck.safe;
        row.safeReason = safeCheck.reason;

        if (settings.safeMode && !row.safe) {
          rejected.push(row);
          continue;
        }

        rows.push(row);
      }
    }

    rows.sort((a, b) => b.ev - a.ev);
    rejected.sort((a, b) => b.ev - a.ev);

    return {
      best: rows[0] || null,
      rows,
      rejected,
      consideredCount,
      openRoleCount,
      missingPayoutCount
    };
  }

  function normaliseCpr(cpr) {
    const n = Number(cpr || 0);
    if (Number.isNaN(n)) return 0;
    return Math.max(0, Math.min(100, n));
  }

  function calculateRisk(weight, payoutMax, cpr) {
    const cprRatio = cpr / 100;
    const affectOnSuccess = 1 - weight * (1 - cprRatio);
    const cprDamage = payoutMax - (payoutMax * affectOnSuccess);
    const riskDamageRatio = payoutMax ? cprDamage / payoutMax : 0;

    let level = 'Low';
    if (riskDamageRatio >= 0.15 || (weight >= 0.35 && cpr < 70)) {
      level = 'High';
    } else if (riskDamageRatio >= 0.08 || (weight >= 0.25 && cpr < 65)) {
      level = 'Medium';
    }

    return {
      cprDamage,
      riskDamageRatio,
      level
    };
  }

  function checkSafeMode(row, settings) {
    if (!settings.safeMode) {
      return { safe: true, reason: 'Safe Mode off' };
    }

    const profile = SAFE_PROFILES[settings.safeModeProfile] || SAFE_PROFILES.balanced;

    if (row.cpr < profile.cprFloor) {
      return {
        safe: false,
        reason: `CPR ${row.cpr}% is below ${profile.label} Safe Mode floor of ${profile.cprFloor}%`
      };
    }

    if (row.weight >= profile.highImpactWeight && row.cpr < profile.highImpactCprFloor) {
      return {
        safe: false,
        reason: `High-impact role needs at least ${profile.highImpactCprFloor}% CPR in ${profile.label} Safe Mode`
      };
    }

    if (row.risk.riskDamageRatio > profile.maxRiskDamageRatio) {
      return {
        safe: false,
        reason: `Risk score too high for ${profile.label} Safe Mode`
      };
    }

    return { safe: true, reason: `${profile.label} Safe Mode passed` };
  }

  function estPayout(weight, payoutMax, cpr, stallHours, members, filled) {
    if (payoutMax == null || members <= 0) return null;

    const expectedWeight = 1 / members;
    const contributionBonus = (weight / expectedWeight) * (cpr / 100);
    const individualPayout = (payoutMax / members) * Math.max(P, contributionBonus);
    const affectOnSuccess = 1 - weight * (1 - (cpr / 100));
    const cprDamage = payoutMax - (payoutMax * affectOnSuccess);
    const stallBonus = (stallHours === 0 && filled === 0)
      ? 1
      : (1 + (K / (1 + Math.sqrt(stallHours))));

    return individualPayout * stallBonus - cprDamage;
  }

  function renderResult(result, source, cacheAgeText) {
    if (!panel) return;

    const settings = getSettings();
